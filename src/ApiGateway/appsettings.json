{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Seq"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://seq:5341"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "Seq": {
    "ServerUrl": "http://seq:5341"
  },
  "Services": {
    "OrderServiceBaseUrl": "http://orderservice:8080",
    "CatalogServiceBaseUrl": "http://productcatalogservice:8080"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "SwaggerEndpoints": [
    {
      "Name": "ProductCatalogService",
      "Url": "/swagger/productcatalog/swagger.json"
    },
    {
      "Name": "InventoryService",
      "Url": "/swagger/inventory/swagger.json"
    },
    {
      "Name": "OrderService",
      "Url": "/swagger/order/swagger.json"
    },
    {
      "Name": "NotificationService",
      "Url": "/swagger/notification/swagger.json"
    }
  ],
  "RabbitMq": {
    "Host": "rabbitmq",
    "Username": "guest",
    "Password": "guest"
  },
  "ReverseProxy": {
    "Routes": {
      "productcatalog-api-categories": {
        "ClusterId": "productcatalog-cluster",
        "Match": {
          "Path": "/api/categories/{**catch-all}"
        },
        "Transforms": []
      },
      "productcatalog-api-categories-root": {
        "ClusterId": "productcatalog-cluster",
        "Match": {
          "Path": "/api/categories"
        },
        "Transforms": []
      },
      "productcatalog-api-products": {
        "ClusterId": "productcatalog-cluster",
        "Match": {
          "Path": "/api/products/{**catch-all}"
        },
        "Transforms": []
      },
      "productcatalog-api-products-root": {
        "ClusterId": "productcatalog-cluster",
        "Match": {
          "Path": "/api/products"
        },
        "Transforms": []
      },
      "productcatalog-api-domain": {
        "ClusterId": "productcatalog-cluster",
        "Match": {
          "Path": "/api/catalog/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/api/catalog"
          },
          {
            "PathPrefix": "/api"
          }
        ]
      },
      "inventory-api-donors": {
        "ClusterId": "inventory-cluster",
        "Match": {
          "Path": "/api/donors/{**catch-all}"
        },
        "Transforms": []
      },
      "inventory-api-donors-root": {
        "ClusterId": "inventory-cluster",
        "Match": {
          "Path": "/api/donors"
        },
        "Transforms": []
      },
      "inventory-api": {
        "ClusterId": "inventory-cluster",
        "Match": {
          "Path": "/api/inventory/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/api/inventory"
          },
          {
            "PathPrefix": "/api"
          }
        ]
      },
      "inventory-api-stock": {
        "ClusterId": "inventory-cluster",
        "Match": {
          "Path": "/api/stock/{**catch-all}"
        },
        "Transforms": []
      },
      "inventory-api-stock-root": {
        "ClusterId": "inventory-cluster",
        "Match": {
          "Path": "/api/stock"
        },
        "Transforms": []
      },
      "order-swagger": {
        "ClusterId": "order-cluster",
        "Match": {
          "Path": "/swagger/order/swagger.json"
        },
        "Transforms": [
          {
            "PathSet": "/swagger/v1/swagger.json"
          }
        ]
      },
      "order-api": {
        "ClusterId": "order-cluster",
        "Match": {
          "Path": "/api/orders/{**catch-all}"
        },
        "Transforms": []
      },
      "order-baskets-api": {
        "ClusterId": "order-cluster",
        "Match": {
          "Path": "/api/baskets/{**catch-all}"
        },
        "Transforms": []
      },
      "order-baskets-api-root": {
        "ClusterId": "order-cluster",
        "Match": {
          "Path": "/api/baskets"
        },
        "Transforms": []
      },
      "order-sales-api": {
        "ClusterId": "order-cluster",
        "Match": {
          "Path": "/api/sales/{**catch-all}"
        },
        "Transforms": []
      },
      "order-sales-api-root": {
        "ClusterId": "order-cluster",
        "Match": {
          "Path": "/api/sales"
        },
        "Transforms": []
      },
      "order-orders-baskets-api": {
        "ClusterId": "order-cluster",
        "Match": {
          "Path": "/api/orders/baskets/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/api/orders"
          }
        ]
      },
      "order-orders-baskets-api-root": {
        "ClusterId": "order-cluster",
        "Match": {
          "Path": "/api/orders/baskets"
        },
        "Transforms": [
          {
            "PathSet": "/api/baskets"
          }
        ]
      },
      "notification-api": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/api/notifications/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/api/notifications"
          },
          {
            "PathPrefix": "/api"
          }
        ]
      },
      "notification-api-reports": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/api/reports/{**catch-all}"
        },
        "Transforms": []
      },
      "notification-api-reports-root": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/api/reports"
        },
        "Transforms": []
      },
      "productcatalog-swagger": {
        "ClusterId": "productcatalog-cluster",
        "Match": {
          "Path": "/swagger/productcatalog/swagger.json"
        },
        "Transforms": [
          {
            "PathSet": "/swagger/v1/swagger.json"
          }
        ]
      },
      "inventory-swagger": {
        "ClusterId": "inventory-cluster",
        "Match": {
          "Path": "/swagger/inventory/swagger.json"
        },
        "Transforms": [
          {
            "PathSet": "/swagger/v1/swagger.json"
          }
        ]
      },
      "notification-swagger": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/swagger/notification/swagger.json"
        },
        "Transforms": [
          {
            "PathSet": "/swagger/v1/swagger.json"
          }
        ]
      },
      "notification-api-winners": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/api/winners/{**catch-all}"
        },
        "Transforms": []
      },
      "notification-api-winners-root": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/api/winners"
        },
        "Transforms": []
      }
    },
    "Clusters": {
      "productcatalog-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://productcatalogservice:8080/"
          },
          "destination2": {
            "Address": "http://productcatalogservice-lb:8080/"
          }
        }
      },
      "inventory-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://inventoryservice:8080/"
          }
        }
      },
      "order-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://orderservice:8080/"
          }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://notificationservice:8080/"
          }
        }
      }
    }
  },
  "AllowedHosts": "*"
}
